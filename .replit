modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 18593
externalPort = 3000

[[ports]]
localPort = 18594
externalPort = 3001

[[ports]]
localPort = 18595
externalPort = 3003

[[ports]]
localPort = 21474
externalPort = 5000

[[ports]]
localPort = 22228
externalPort = 5173

[userenv]

[userenv.shared]

[userenv.development]
ELEVENLABS_API_KEY = "6e6ca8d3c96256409bf197b076d0ede7fae7183d9bc02374d1e2be55fdd71342"
ELEVENLABS_VOICE_ID = "8RV9Jl85RVagCJGw9qhY"

